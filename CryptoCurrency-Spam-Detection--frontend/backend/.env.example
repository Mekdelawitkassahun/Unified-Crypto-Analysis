# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=crypto_intelligence

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Blockchain Engine (Python) ──────────────────────────────────────────────
BLOCKCHAIN_API_URL=http://127.0.0.1:8055
# Python engine scans can be slow without EXPLORER_API_KEY; allow 30s+ if needed
BLOCKCHAIN_ENGINE_TIMEOUT_MS=15000

# ─── External APIs ───────────────────────────────────────────────────────────
MORALIS_API_KEY=
# Etherscan V2 key (works for ETH, BSC, Polygon, Arbitrum, Optimism, Base)
EXPLORER_API_KEY=

# ─── RPC Endpoints (optional overrides — public nodes used by default) ────────
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
FANTOM_RPC_URL=https://rpc.fantom.network
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h

# ─── Internal API Key (for /api/v1/internal/* endpoints) ─────────────────────
API_KEY=change-this-api-key

# ─── Webhooks ────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-this-webhook-secret
WEBHOOK_TIMEOUT=5000

# ─── Email ───────────────────────────────────────────────────────────────────
# Pick ONE of the three options below. Priority: Resend > Gmail > SMTP

# Option 1 — Resend (recommended, free tier 3000 emails/month)
# Sign up at https://resend.com, get an API key, verify a domain or use onboarding@resend.dev for testing
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=CryptoShield <alerts@yourdomain.com>

# Option 2 — Gmail (free, requires an App Password — NOT your normal password)
# Enable 2FA on your Google account, then go to:
# https://myaccount.google.com/apppasswords → create an app password for "Mail"
# GMAIL_USER=yourname@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option 3 — Generic SMTP (any SMTP server)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# EMAIL_FROM=alerts@example.com

# ─── WebSocket Alerts ────────────────────────────────────────────────────────
# Frontend env: VITE_ALERTS_WS_URL=ws://localhost:3000/ws
